{
    "$schema": "https://cmake.org/cmake/help/latest/_downloads/3e2d73bff478d88a7de0de736ba5e361/schema.json",
    "version": 8,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 24
    },
    "configurePresets": [
        {
            "name": "base_dev",
            "hidden": true,
            "binaryDir": "build",
            "installDir": "install",
            "cacheVariables": {
                "BUILD_EXAMPLES": "ON",
                "BUILD_TESTING": "ON"
            }
        },
        {
            "name": "dev_linux",
            "displayName": "Linux Dev",
            "hidden": false,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            },
            "inherits": [
                "base_dev"
            ],
            "generator": "Ninja Multi-Config"
        },
        {
            "name": "dev_macos",
            "displayName": "MacOS Dev",
            "hidden": false,
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            },
            "inherits": [
                "base_dev"
            ],
            "generator": "Ninja Multi-Config"
        },
        {
            "name": "dev_wasm",
            "displayName": "Wasm Dev",
            "hidden": false,
            "binaryDir": "build_wasm",
            "installDir": "install_wasm",
            "inherits": [
                "base_dev"
            ],
            "cacheVariables": {
                "CMAKE_TOOLCHAIN_FILE": "$env{EMSCRIPTEN_ROOT}/cmake/Modules/Platform/Emscripten.cmake"
            },
            "generator": "Ninja Multi-Config"
        },
        {
            "name": "dev_xwin_clang_cl",
            "displayName": "Clang CL with xwin",
            "description": "For cross compiling to windows on linux",
            "hidden": false,
            "binaryDir": "build_xwin",
            "installDir": "install_xwin",
            "inherits": [
                "base_dev"
            ],
            "environment": {
                "XWIN_DIR": "${sourceDir}/.xwin",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/cmake/toolchains/xwin-clang-cl.cmake"
            },
            "generator": "Ninja Multi-Config"
        }
    ],
    "buildPresets": [
        {
            "name": "base_dev",
            "hidden": true,
            "configuration": "Debug"
        },
        {
            "name": "dev_linux",
            "displayName": "Linux Dev",
            "inherits": [
                "base_dev"
            ],
            "configurePreset": "dev_linux",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "dev_macos",
            "displayName": "MacOS Dev",
            "inherits": [
                "base_dev"
            ],
            "configurePreset": "dev_macos",
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "dev_wasm",
            "displayName": "Wasm Dev",
            "inherits": [
                "base_dev"
            ],
            "configurePreset": "dev_wasm"
        },
        {
            "name": "dev_xwin_clang_cl",
            "displayName": "Clang CL with xwin",
            "inherits": [
                "base_dev"
            ],
            "configurePreset": "dev_xwin_clang_cl"
        }
    ]
}
